# Nomad/Panshi Studio non-secret settings. Copy to /etc/panshi/studio.env.
AUTO_PUBLISH=true
YOUTUBE_VISIBILITY=public

SITE_URL=https://panshi.nomadsustaintech.com
PANSHI_STUDIO_IMAGE=panshi-studio:current
PANSHI_DATA_DIR=/path/to/panshi-data
PANSHI_STUDIO_DIR=/path/to/panshi-studio
MARKET_DB_PATH=/app/runtime-data/panshi-market.db
STUDIO_DB_PATH=/app/runtime-data/panshi-studio.db
STUDIO_OUTPUT_ROOT=/app/var/panshi-studio
STUDIO_PRESENTER_PATH=/app/studio/assets/moheng-virtual-host.png
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
REMOTION_BROWSER_EXECUTABLE=/usr/bin/chromium
REMOTION_CONCURRENCY=1

STUDIO_TTS_MODEL=gpt-4o-mini-tts
STUDIO_TTS_VOICE=onyx
STUDIO_TTS_SPEED=0.96
YOUTUBE_REGION=TW
YOUTUBE_CATEGORY_NAME=Education
YOUTUBE_NOTIFY_SUBSCRIBERS=true
YOUTUBE_CHANNEL_ID=UCycI7woWFpc3bH2JIZsC80g
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:53682
STUDIO_PUBLISH_MAX_ATTEMPTS=5
STUDIO_PUBLISH_RETRY_BASE_SECONDS=300
STUDIO_UPLOAD_STALE_MINUTES=20

# Deployment allowlists secrets from the central vault into two root-only,
# mode-600 Docker env files loaded by systemd LoadCredential. Never put values here.
# /etc/panshi/credentials/studio-generate.env: OPENAI_API_KEY only
# /etc/panshi/credentials/studio-publish.env: YOUTUBE_OAUTH_CLIENT_ID,
# YOUTUBE_OAUTH_CLIENT_SECRET, and YOUTUBE_REFRESH_TOKEN only
# STUDIO_REVIEW_TOKEN is a separate Web-container secret and never enters either worker.
