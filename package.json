{
  "name": "panshi-company-market-astrology",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start -H 0.0.0.0",
    "test": "npm run build && npm run test:standalone && node --test tests/rendered-html.test.mjs && npm run test:logic",
    "test:logic": "tsx --test tests/inquiry-logic.test.ts",
    "test:standalone": "node scripts/assert-standalone-clean.mjs",
    "test:studio": "tsx --test studio/__tests__/*.test.ts",
    "test:browser": "node scripts/browser-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "backfill:market": "node --import ./scripts/register-path-alias.mjs scripts/backfill-market-history.ts",
    "update:market": "node --import ./scripts/register-path-alias.mjs scripts/update-latest-market-day.ts",
    "studio:generate": "tsx studio/commands/generate-daily.ts",
    "studio:publish": "tsx studio/commands/publish-ready.ts",
    "studio:oauth": "tsx studio/commands/oauth-youtube.ts",
    "studio:preview": "remotion studio studio/remotion/index.ts --public-dir=studio/assets/remotion-public",
    "studio:compositions": "remotion compositions studio/remotion/index.ts --public-dir=studio/assets/remotion-public",
    "lint": "eslint . --ignore-pattern .next --ignore-pattern dist"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@remotion/captions": "4.0.489",
    "@remotion/cli": "4.0.489",
    "@remotion/fonts": "4.0.489",
    "@remotion/media": "4.0.489",
    "@remotion/paths": "4.0.489",
    "@remotion/transitions": "4.0.489",
    "astronomy-engine": "^2.1.19",
    "motion": "^12.42.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "remotion": "4.0.489",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "tsx": "^4.23.0",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.16"
  },
  "type": "module"
}
